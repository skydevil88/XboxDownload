<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="250"
        xmlns:converters="clr-namespace:XboxDownload.Converters"
        xmlns:dialog="clr-namespace:XboxDownload.ViewModels.Dialog"
        x:Class="XboxDownload.Views.Dialog.UsbDriveDialog"
        x:CompileBindings="False"
        WindowStartupLocation="CenterOwner"
        Width="980" Height="250"
        Title="Usb Device (MBR磁盘存在2TB分区限制，超出后的容量无法被使用)">

    <Window.Resources>
        <converters:EnumToBoolConverter x:Key="EnumToBoolConverter"/>
    </Window.Resources>

    <Grid RowDefinitions="*,Auto" ColumnDefinitions="*,100,*" Margin="10" RowSpacing="5" x:DataType="dialog:UsbDriveDialogViewModel">
        <DataGrid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" IsReadOnly="True" CanUserSortColumns="False" GridLinesVisibility="All"
                  BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                  ItemsSource="{Binding UsbDriveMappings}"
                  SelectedItem="{Binding SelectedEntry}">
            <DataGrid.Columns>
                <DataGridTemplateColumn MinWidth="40" Header="编号">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="dialog:UsbDriveDialogViewModel+UsbDriveMappingEntry">
                            <TextBlock Text="{Binding Index}" Margin="6,0" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="*" Header="型号">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="dialog:UsbDriveDialogViewModel+UsbDriveMappingEntry">
                            <TextBlock Text="{Binding Model}" Margin="6,0" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn MinWidth="40" Header="接口">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="dialog:UsbDriveDialogViewModel+UsbDriveMappingEntry">
                            <TextBlock Text="{Binding InterfaceType}" Margin="6,0" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn MinWidth="80" Header="容量">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="dialog:UsbDriveDialogViewModel+UsbDriveMappingEntry">
                            <TextBlock Text="{Binding FormatSize}" Margin="6,0" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn MinWidth="40" Header="分区表">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="dialog:UsbDriveDialogViewModel+UsbDriveMappingEntry">
                            <TextBlock Text="{Binding PartitionScheme}" Margin="6,0" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn MinWidth="40" Header="分区数">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="dialog:UsbDriveDialogViewModel+UsbDriveMappingEntry">
                            <TextBlock Text="{Binding Partitions}" Margin="6,0" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn MinWidth="40" Header="盘符">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="dialog:UsbDriveDialogViewModel+UsbDriveMappingEntry">
                            <TextBlock Text="{Binding DriveLetter}" Margin="6,0" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="1" Grid.Column="0" ColumnDefinitions="Auto,*,Auto">
            <Button Grid.Column="0" Classes="LinkLabel" Command="{Binding RefreshUsbDrivesCommand}">
                <TextBlock Text="刷新" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
            </Button>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right">
                <TextBlock VerticalAlignment="Center" TextWrapping="Wrap" Text="分区表类型"/>
                <RadioButton Content="GPT"
                             IsChecked="{Binding DiskPartitionType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Gpt}"/>
                <RadioButton Content="MBR"
                             IsChecked="{Binding DiskPartitionType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Mbr}"/>
            </StackPanel>
        </Grid>

        <Button Grid.Row="1" Grid.Column="1" MinWidth="80" HorizontalContentAlignment="Center" HorizontalAlignment="Center" Content="重新分区"
                IsEnabled="{Binding IsEnabled}"
                Command="{Binding RepartitionCommand}"/>

        <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Text="分区过程中弹出格式化或者其它错误信息请忽略取消"/>

    </Grid>

</Window>
